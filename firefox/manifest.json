{
  "manifest_version": 2,
  "name": "Into the Grape Vine",
  "version": "0.1.0",
  "description": "Captures Amazon Vine order data and syncs to your Dropbox Excel sheet.",
  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "https://www.amazon.com/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.amazon.com/vine/orders*"],
      "js": ["utils.js", "vine-orders.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.amazon.com/your-orders*",
        "https://www.amazon.com/gp/your-account/order-history*",
        "https://www.amazon.com/gp/css/order-history*",
        "https://www.amazon.com/gp/*/order-history*"
      ],
      "js": ["utils.js", "account-orders.js"],
      "run_at": "document_idle"
    }
  ],
  "background": { "scripts": ["background.js"], "persistent": false },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Into the Grape Vine"
  },
  "browser_specific_settings": {
    "gecko": { "id": "into-the-grape-vine@local", "strict_min_version": "109.0" }
  }
}
