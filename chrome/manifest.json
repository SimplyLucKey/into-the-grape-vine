{
  "manifest_version": 3,
  "name": "Into the Grape Vine",
  "version": "0.1.0",
  "description": "Captures Amazon Vine order data and syncs to your Dropbox Excel sheet.",
  "permissions": ["storage", "alarms", "activeTab", "scripting"],
  "host_permissions": ["https://www.amazon.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.amazon.com/vine/orders*"],
      "js": ["utils.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.amazon.com/your-orders*",
        "https://www.amazon.com/gp/your-account/order-history*",
        "https://www.amazon.com/gp/css/order-history*",
        "https://www.amazon.com/gp/*/order-history*"
      ],
      "js": ["utils.js", "content-orders.js"],
      "run_at": "document_idle"
    }
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Into the Grape Vine"
  }
}
